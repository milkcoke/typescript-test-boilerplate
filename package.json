{
  "name": "nxcmd-http-dummy-nodejs-server",
  "version": "1.0.0",
  "description": "게임 연동 더미서버 프로젝트",
  "author": "",
  "private": true,
  "license": "",
  "repository": {
    "type": "git",
    "url": "https://gitlab.nexon.com/mwp/nxcmd/miscellaneous/nxcommand-pilot/nxcmd-http-dummy-nodejs-server"
  },
  "scripts": {
    "build": "nest build",
    "start": "ts-node src/app.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "dependencies": {
    "express": "^4.18.2",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.16",
    "@types/jest": "29.4.0",
    "@types/js-yaml": "^4.0.5",
    "@types/node": "18.11.18",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^5.50.0",
    "@typescript-eslint/parser": "^5.50.0",
    "eslint": "^8.33.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.4.3",
    "source-map-support": "^0.5.21",
    "ts-jest": "29.0.5",
    "ts-loader": "^9.4.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "4.1.2",
    "typescript": "^4.9.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "ts", "js"
    ],
    "rootDir": "test",
    "testRegex": ".*|(\\\\.|/)(test|spec)\\\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
